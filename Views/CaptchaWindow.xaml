<Window x:Class="DDTankLauncher.Views.CaptchaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="验证码" 
        Height="280" Width="350"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="请输入验证码" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,15"/>
            
            <!-- 验证码图片 -->
            <Border Background="White" CornerRadius="5" Padding="5" Margin="0,0,0,15"
                    HorizontalAlignment="Center">
                <Image x:Name="CaptchaImage" Width="120" Height="40"/>
            </Border>
            
            <!-- 验证码输入 -->
            <TextBox x:Name="CaptchaBox" FontSize="18" Padding="10,8" Margin="0,0,0,15"
                     Background="#16213e" Foreground="White" BorderBrush="#333"
                     HorizontalContentAlignment="Center" MaxLength="6"/>
            
            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="刷新" Click="Refresh_Click"
                        Background="#2196F3" Foreground="White"
                        BorderThickness="0" Padding="15,8" FontSize="13"
                        Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="确定" Click="Confirm_Click"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Padding="15,8" FontSize="13"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
