<Window x:Class="DDTankLauncher.Views.DuplicateAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现重复账号" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Image Source="pack://application:,,,/Resources/warning.png" 
                   Width="48" Height="48" 
                   Margin="0,0,15,0" />
            <TextBlock Text="检测到重复账号" FontSize="16" FontWeight="Bold" 
                       VerticalAlignment="Center" />
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" Margin="0,0,0,15">
            <TextBlock x:Name="MessageText" FontSize="14" TextWrapping="Wrap" />
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OverwriteBtn" Content="覆盖" Width="80" Height="30"
                    Click="OverwriteBtn_Click" Margin="0,0,10,0" />
            <Button x:Name="SkipBtn" Content="跳过" Width="80" Height="30"
                    Click="SkipBtn_Click" Margin="0,0,10,0" />
            <Button x:Name="AddAllBtn" Content="仍要添加" Width="80" Height="30"
                    Click="AddAllBtn_Click" />
        </StackPanel>
    </Grid>
</Window>