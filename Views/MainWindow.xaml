<Window x:Class="DDTankLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DDTankLauncher"
        Title="弹弹堂登录器"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <local:RemarkVisibilityConverter x:Key="RemarkVisibility"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
        <local:BooleanToInverseVisibilityConverter x:Key="BooleanToInverseVisibility"/>
        
        <Style x:Key="AccountBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="true">
                    <Setter Property="Background" Value="#1a476e"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00d4ff" BlurRadius="15" Opacity="0.8" Direction="360"/>
                        </Setter.Value>
                    </Setter>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation 
                                    Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                    From="0.4" To="1.0" Duration="0:0:1.5" 
                                    AutoReverse="True"/>
                                <DoubleAnimation 
                                    Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                    From="10" To="25" Duration="0:0:1.5" 
                                    AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🎮" FontSize="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="弹弹堂登录器" FontSize="28" FontWeight="Bold" 
                       Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- 账号列表 -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="10" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="AddAccountBtn" Content="➕ 添加账号" 
                            Click="AddAccount_Click"
                            Background="#4CAF50" Foreground="White" 
                            BorderThickness="0" Padding="15,8" FontSize="14"
                            Cursor="Hand"/>
                    <Button x:Name="RefreshBtn" Content="🔄 刷新" 
                            Click="Refresh_Click"
                            Background="#2196F3" Foreground="White" 
                            BorderThickness="0" Padding="15,8" FontSize="14"
                            Margin="10,0,0,0" Cursor="Hand"/>
                    
                    <!-- 分组按钮 1-10 -->
                    <Button Content="1" Click="Group1_Click" x:Name="Group1Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="10,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="2" Click="Group2_Click" x:Name="Group2Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="3" Click="Group3_Click" x:Name="Group3Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="4" Click="Group4_Click" x:Name="Group4Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="5" Click="Group5_Click" x:Name="Group5Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="6" Click="Group6_Click" x:Name="Group6Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="7" Click="Group7_Click" x:Name="Group7Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="8" Click="Group8_Click" x:Name="Group8Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="9" Click="Group9_Click" x:Name="Group9Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="35"/>
                    <Button Content="10" Click="Group10_Click" x:Name="Group10Btn" Style="{x:Null}"
                            Background="#9C27B0" Foreground="White" 
                            BorderThickness="0" Padding="8,8" FontSize="12"
                            Margin="5,0,0,0" Cursor="Hand" Width="40"/>
                </StackPanel>
                
                <!-- 账号列表 -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AccountList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AccountBorderStyle}"
                                            MouseLeftButtonUp="Account_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" 
                                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                                      ClickMode="Press" Cursor="Hand"/>
                                            
                                            <Border Grid.Column="1" Background="#533483" CornerRadius="25" 
                                                    Width="50" Height="50" VerticalAlignment="Center">
                                                <TextBlock Text="👤" FontSize="24" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="2" Margin="15,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" FontSize="16" FontWeight="Bold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding Server}" FontSize="12"
                                                           Foreground="#AAAAAA" Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding Remark}" FontSize="11"
                                                           Foreground="#888888" Margin="0,3,0,0"
                                                           Visibility="{Binding Remark, Converter={StaticResource RemarkVisibility}}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" 
                                                           FontSize="12" Foreground="#4CAF50"
                                                           HorizontalAlignment="Right"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="编辑" Click="EditAccount_Click"
                                                            Tag="{Binding Username}"
                                                            Background="Transparent" Foreground="#2196F3"
                                                            BorderThickness="0" FontSize="12"
                                                            Padding="5,2" Cursor="Hand"
                                                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToInverseVisibility}}"/>
                                                    <Button Content="删除" Click="DeleteAccount_Click"
                                                            Tag="{Binding Username}"
                                                            Background="Transparent" Foreground="#FF5252"
                                                            BorderThickness="0" FontSize="12"
                                                            Padding="5,2" Cursor="Hand"
                                                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToInverseVisibility}}"/>
                                                    <Button Content="⏹️ 停止" Click="StopAccount_Click"
                                                            Tag="{Binding Username}"
                                                            Background="Transparent" Foreground="#FF9800"
                                                            BorderThickness="0" FontSize="12"
                                                            Padding="5,2" Cursor="Hand"
                                                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibility}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <StackPanel x:Name="EmptyHint" VerticalAlignment="Center" 
                                HorizontalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无账号，点击上方[添加账号]开始" 
                                   Foreground="#666666" FontSize="14"
                                   Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        
        <!-- 底部操作栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
            <Button x:Name="SelectAllBtn" Content="全选" 
                    Click="SelectAll_Click"
                    Background="#607D8B" Foreground="White" 
                    BorderThickness="0" Padding="10,5" FontSize="12"
                    Cursor="Hand"/>
            <Button x:Name="SelectNoneBtn" Content="取消全选" 
                    Click="SelectNone_Click"
                    Background="#607D8B" Foreground="White" 
                    BorderThickness="0" Padding="10,5" FontSize="12"
                    Margin="10,0,0,0" Cursor="Hand"/>
            <Button x:Name="BatchDeleteBtn" Content="🗑️ 批量删除" 
                    Click="BatchDelete_Click"
                    Background="#FF5252" Foreground="White" 
                    BorderThickness="0" Padding="10,5" FontSize="12"
                    Margin="10,0,0,0" Cursor="Hand"/>
            <TextBlock x:Name="SelectedCount" Text="已选择 0 个" 
                       Foreground="#888888" FontSize="12"
                       Margin="10,0,0,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="BottomStatus" Text="就绪" 
                       Foreground="#888888" FontSize="12"
                       Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
