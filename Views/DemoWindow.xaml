<Window x:Class="DDTankLauncher.Views.DemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="窗口特征测试" 
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="点击按钮创建不同类型的游戏窗口，然后用脚本测试能否识别" 
                   Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,15"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 方案1: 36脚本大厅类名 -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案1: 36JBCOM_Browser 类名" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="类名=36JBCOM_Browser, 标题=[4399-132-测试]|1|测试|0|0|0" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="Create36JBWindow" Background="#4CAF50" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 方案2: Tango3 类名 -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案2: Tango3 类名" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="类名=Tango3, 标题=4399弹弹堂-测试-(132服)--4399网页游戏" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="CreateTangoWindow" Background="#2196F3" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 方案3: ShockwaveFlash + 标题 -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案3: ShockwaveFlash + 游戏标题" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="类名=ShockwaveFlash, 标题=4399弹弹堂-测试-(132服)" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="CreateFlashWithTitle" Background="#FF9800" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 方案4: 36JBCOM_Browser + ShockwaveFlash子窗口 -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案4: 36JBCOM_Browser + ShockwaveFlash 子窗口" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="父窗口类名=36JBCOM_Browser, 子窗口类名=ShockwaveFlash" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="Create36JBWithFlashChild" Background="#9C27B0" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 方案5: MacromediaFlashPlayerActiveX -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案5: MacromediaFlashPlayerActiveX 类名" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="类名=MacromediaFlashPlayerActiveX, 标题=Adobe Flash Player 34" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="CreateMacromediaWindow" Background="#E91E63" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 方案6: 完整36脚本大厅结构 -->
                <Border Background="#0f3460" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="方案6: 完整36脚本大厅结构 (36JBCOM_Browser > _EL_PicBox > ShockwaveFlash)" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="模拟36脚本大厅的完整窗口层级结构" Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,10"/>
                        <Button Content="创建窗口" Click="CreateFullStructure" Background="#00BCD4" Foreground="White" BorderThickness="0" Padding="15,8" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
                
                <!-- 状态显示 -->
                <Border Background="#16213e" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="已创建的窗口:" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="StatusText" Text="无" Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
